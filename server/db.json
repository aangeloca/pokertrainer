  "glossary": [
    {
      "term": "GTO",
      "definition": "Game Theory Optimal: estrategia balanceada que dificulta ser explorado no longo prazo."
    },
    {
      "term": "Range",
      "definition": "Conjunto de maos que um jogador pode ter em uma linha especifica."
    },
    {
      "term": "MDF",
      "definition": "Minimum Defense Frequency: frequencia minima de defesa para nao ser explorado por blefes automaticos."
    },
    {
      "term": "Pot odds",
      "definition": "Preco do call comparado ao tamanho final do pote; ajuda a decidir se a equidade basta."
    },
    {
      "term": "Blocker",
      "definition": "Carta na sua mao que reduz combinacoes fortes ou de blefe no range adversario."
    }
